# Copy to .env on the server and fill in. NEVER commit the real .env.

# --- Image ---
# Pull from your fork's GHCR (built by .github/workflows/townbrief-image.yml), or
# set to a locally-built tag (townbrief-ghost:local) if you built with build-image.sh.
GHOST_IMAGE=ghcr.io/davevwatkins/ghost:latest

# --- Public site ---
GHOST_DOMAIN=wayland.townbrief.com
GHOST_URL=https://wayland.townbrief.com

# --- MySQL (pick strong values) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_root
MYSQL_DATABASE=ghost
MYSQL_USER=ghost
MYSQL_PASSWORD=CHANGE_ME

# --- Mail (transactional: member login magic links, staff invites) ---
# Any SMTP works for transactional. Bulk NEWSLETTERS require Mailgun set up in Ghost Admin.
MAIL_FROM=Wayland Post <noreply@townbrief.com>
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
