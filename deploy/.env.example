# Copy to .env on the server and fill in. NEVER commit the real .env.
# PRODUCTION stack = multitenant Postgres + RLS Ghost fork. See deploy/README.md.

# --- Images ---
# Ghost: pull from GHCR (built by .github/workflows/townbrief-image.yml), or build
# locally with deploy/build-image.sh and set GHOST_IMAGE=townbrief-ghost:local.
GHOST_IMAGE=ghcr.io/davevwatkins/ghost:latest
# Caddy is built locally from deploy/Dockerfile.caddy (it needs a DNS plugin). Leave as
# the default local tag unless you push a pre-built image somewhere.
CADDY_IMAGE=townbrief-caddy:local

# --- Public site ---
# Fallback/admin origin. In the multitenant install each town's URL is derived per
# request from the `sites` table; this is the base + admin URL. Use the apex or the
# primary pub host.
GHOST_PUBLIC_URL=https://wayland.townbrief.com

# --- Postgres ---
# POSTGRES_USER is the bootstrap SUPERUSER (ops + migrations only). Ghost connects as the
# NON-super GHOST_APP_USER so Row-Level Security actually enforces. Keep them DISTINCT and
# both strong.
POSTGRES_USER=ghost_super
POSTGRES_PASSWORD=CHANGE_ME_postgres_superuser
POSTGRES_DB=ghost_prod
GHOST_APP_USER=ghost_app
GHOST_APP_PASSWORD=CHANGE_ME_ghost_app_runtime

# --- Wildcard TLS (DNS-01) ---
# At hundreds of *.townbrief.com subdomains, per-subdomain HTTP-01 hits Let's Encrypt's
# ~50 certs/week/registered-domain cap, so we use ONE wildcard cert via DNS-01. That needs
# townbrief.com's DNS on a provider Caddy can solve against. The default Caddy build bundles
# the Cloudflare plugin: put townbrief.com's DNS on Cloudflare (free) and create a scoped
# API token (Zone:DNS:Edit for townbrief.com). To use a different provider, swap the plugin
# in deploy/Dockerfile.caddy and the `dns` directive in deploy/Caddyfile.
ACME_EMAIL=dave@townbrief.com
CLOUDFLARE_API_TOKEN=CHANGE_ME_cloudflare_zone_dns_edit_token

# --- Mail (transactional: member login magic links, staff invites) ---
# Any SMTP works for transactional. Bulk NEWSLETTERS require a Mailgun account configured
# per-site in Ghost Admin.
MAIL_FROM=Town Brief <noreply@townbrief.com>
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Superadmin dashboard + single sign-on (superadmin.townbrief.com) ---
# Log in HERE once and every town's /ghost auto-signs-you-in (the *.townbrief.com
# gateway redirects unauthenticated admin visits to this tool's SSO). It reads
# across ALL tenants as the Postgres SUPER user above. Use a STRONG password and a
# long random session secret — this login is the keys to every town's admin.
SUPERADMIN_USER=admin
SUPERADMIN_PASS=CHANGE_ME_strong_superadmin_password
SUPERADMIN_SESSION_SECRET=CHANGE_ME_long_random_session_secret_32B+
# Default-site host the dashboard links to + reads the SSO signing secret from.
SUPERADMIN_GHOST_HOST=middlesexcounty.townbrief.com
SUPERADMIN_IMAGE=townbrief-superadmin:local

# --- Resource limits (stability under load) ---
# Bound each container so a spike OOM-restarts predictably (restart: always) instead of
# thrashing/OOM-killing the host. Size to YOUR server; these defaults suit a ~4-8 GB box.
# Keep the Ghost heap cap ~1.5x UNDER GHOST_MEM_LIMIT so Node OOMs cleanly. The in-memory
# all-tenants state grows with tenant count — monitor Ghost RSS and raise these as you scale
# (or pursue lazy per-site state). All optional; the compose files have these same defaults.
GHOST_MEM_LIMIT=3g
GHOST_MEM_RESERVATION=1g
GHOST_NODE_HEAP_MB=2048
GHOST_CPUS=2
POSTGRES_MEM_LIMIT=2g
POSTGRES_CPUS=2
REDIS_MAXMEM=512mb
REDIS_MEM_LIMIT=1g
