# Fleet secrets/config. Copy to `.env` (gitignored) on the server and fill in.
# docker compose interpolates these into the generated compose.fleet.yaml.

# Forked Ghost image (built + published by .github/workflows/townbrief-image.yml)
GHOST_IMAGE=ghcr.io/davevwatkins/ghost:latest

# Shared MySQL root password (one MySQL server, one DB per town)
MYSQL_ROOT_PASSWORD=CHANGE_ME_root

# Shared transactional SMTP (login/password/2FA mail). Port 2525 works on DigitalOcean
# without an unblock; use 587 if DO has unblocked it (e.g. Google Workspace).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

# Per-town database passwords are appended automatically by add-town.sh, e.g.:
# DBPASS_wayland=...
# DBPASS_sudbury=...
