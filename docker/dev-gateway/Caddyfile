{
    admin off

    # Souin edge cache (cache-handler plugin). Config only — caching is enabled
    # PER-ROUTE below and ONLY when WP_EDGE_CACHE=on, so normal dev stays uncached.
    # Cache keys are method+HOST+path → each *.localtest.me tenant is isolated.
    cache {
        ttl {$WP_EDGE_CACHE_TTL:60s}
        stale {$WP_EDGE_CACHE_STALE:600s}
    }
}

# Front-end proxy to Ghost — shared by the cache / no-cache handlers below.
(ghost_proxy) {
    reverse_proxy {env.GHOST_BACKEND} {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto https
    }
}

# TownBrief superadmin dashboard
superadmin.localtest.me:80 {
    reverse_proxy ghost-dev-superadmin:3001
}

# TownBrief apex landing-page preview — mirrors production's townbrief.com apex
# (deploy/site), with town links rewritten to *.localtest.me so click-through hits
# the local tenants. Lets you see apex + towns behavior before the prod cutover.
townbrief.localtest.me:80 {
    root * /srv/site
    file_server
    encode gzip
}

:80 {
    # Compact log format for development
    log {
        output stdout
        format transform "{common_log}"
    }

    # Gateway rate cap (caddy-ratelimit). Default threshold is effectively unlimited so it
    # never bites normal dev or load tests; set WP_RATE_LIMIT_EVENTS low (e.g. 300) to shed
    # per-IP floods as 429 at the edge instead of saturating Ghost. See deploy/EDGE-CACHING.md.
    rate_limit {
        zone tb_perip {
            key {remote_host}
            events {$WP_RATE_LIMIT_EVENTS:100000}
            window 1m
        }
    }

    # TownBrief single sign-on ("log in once"): if you open a town's /ghost admin
    # WITHOUT a Ghost admin session, bounce to the superadmin SSO for that site.
    # After ONE superadmin login, every town auto-signs-in on visit — no per-site
    # passwords. Guards against loops via the session cookie + ?sso=1 (the redeem
    # redirects back to /ghost/?sso=1, by which point the session cookie is set).
    # `redir` is evaluated before the `handle` blocks below, so it intercepts the
    # admin HTML entry only (NOT /ghost/api or /ghost/assets, which differ in path).
    @admin_no_session {
        host *.localtest.me
        path /ghost /ghost/
        not header Cookie *ghost-admin-api-session=*
        not query sso=1
    }
    redir @admin_no_session http://superadmin.localtest.me/sso/{http.request.host.labels.2}?next=%2Fghost%2F%3Fsso%3D1

    # Ember live reload (runs on separate port 4201)
    # This handles both the script injection and WebSocket connections
    handle /ember-cli-live-reload.js {
        reverse_proxy {env.ADMIN_LIVE_RELOAD_SERVER} {
            header_up Host {http.reverse_proxy.upstream.hostport}
            header_up X-Forwarded-Host {host}
            # Enable WebSocket support for live reload
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
        }
    }

    # Ghost API - must go to Ghost backend, not admin dev server
    handle /ghost/api/* {
        reverse_proxy {env.GHOST_BACKEND} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}

            # Always tell Ghost requests are HTTPS to prevent redirects
            header_up X-Forwarded-Proto https
        }
    }

    # Analytics API - proxy analytics requests to analytics service
    # Handles paths like /.ghost/analytics/* or /blog/.ghost/analytics/*
    @analytics_paths path_regexp analytics_match ^(.*)/\.ghost/analytics(.*)$
    handle @analytics_paths {
        rewrite * {re.analytics_match.2}
        reverse_proxy {env.ANALYTICS_PROXY_TARGET} {
            header_up Host {host}
            header_up X-Forwarded-Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }

    # ActivityPub API - proxy activityPub requests to activityPub service (running in separate project)
    # Requires activitypub containers to be running via the ActivityPub project's docker-compose
    handle /.ghost/activitypub/* {
        reverse_proxy {env.ACTIVITYPUB_PROXY_TARGET} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # WebFinger - required for ActivityPub federation
    handle /.well-known/webfinger {
        reverse_proxy {env.ACTIVITYPUB_PROXY_TARGET} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # NodeInfo - required for ActivityPub federation
    handle /.well-known/nodeinfo {
        reverse_proxy {env.ACTIVITYPUB_PROXY_TARGET} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # Public app dev server assets - must come BEFORE general /ghost/* handler
    # Ghost is configured to load these from /ghost/assets/* via compose.dev.yaml
    handle /ghost/assets/* {
        # Strip /ghost/assets/ prefix
        uri strip_prefix /ghost/assets

        # Koenig Lexical Editor (optional - for developing Lexical in separate Koenig repo)
        # Requires EDITOR_URL=/ghost/assets/koenig-lexical/ when starting admin dev server
        # Falls back to Ghost backend (built package) via handle_errors if dev server isn't running
        @lexical path /koenig-lexical/*
        handle @lexical {
            uri strip_prefix /koenig-lexical
            reverse_proxy {env.LEXICAL_DEV_SERVER} {
                header_up Host {http.reverse_proxy.upstream.hostport}
                header_up X-Forwarded-Host {host}
                # Fail quickly if dev server is down
                fail_duration 1s
                unhealthy_request_count 1
            }
        }

        # Public app dev servers: when running, the host dev server gets the
        # request; when down (502/connection refused), the request fails fast
        # so handle_errors below can fall back to the bundled assets that
        # Ghost serves out of ghost/core/core/built/. That mirrors what
        # /ghost/assets/koenig-lexical/* already does and lets the public
        # frontend (Portal signin/subscribe, comments, search, etc.) work
        # without a developer having to start every `pnpm dev` separately.

        # Portal
        @portal path /portal/*
        handle @portal {
            uri strip_prefix /portal
            reverse_proxy {env.PORTAL_DEV_SERVER} {
                header_up Host {http.reverse_proxy.upstream.hostport}
                header_up X-Forwarded-Host {host}
                fail_duration 1s
                unhealthy_request_count 1
            }
        }

        # Comments UI
        @comments path /comments-ui/*
        handle @comments {
            uri strip_prefix /comments-ui
            reverse_proxy {env.COMMENTS_DEV_SERVER} {
                header_up Host {http.reverse_proxy.upstream.hostport}
                header_up X-Forwarded-Host {host}
                fail_duration 1s
                unhealthy_request_count 1
            }
        }

        # Signup Form
        @signup path /signup-form/*
        handle @signup {
            uri strip_prefix /signup-form
            reverse_proxy {env.SIGNUP_DEV_SERVER} {
                header_up Host {http.reverse_proxy.upstream.hostport}
                header_up X-Forwarded-Host {host}
                fail_duration 1s
                unhealthy_request_count 1
            }
        }

        # Sodo Search
        @search path /sodo-search/*
        handle @search {
            uri strip_prefix /sodo-search
            reverse_proxy {env.SEARCH_DEV_SERVER} {
                header_up Host {http.reverse_proxy.upstream.hostport}
                header_up X-Forwarded-Host {host}
                fail_duration 1s
                unhealthy_request_count 1
            }
        }

        # Announcement Bar
        @announcement path /announcement-bar/*
        handle @announcement {
            uri strip_prefix /announcement-bar
            reverse_proxy {env.ANNOUNCEMENT_DEV_SERVER} {
                header_up Host {http.reverse_proxy.upstream.hostport}
                header_up X-Forwarded-Host {host}
                fail_duration 1s
                unhealthy_request_count 1
            }
        }

        # Admin Toolbar
        @admin-toolbar path /admin-toolbar/*
        handle @admin-toolbar {
            uri strip_prefix /admin-toolbar
            reverse_proxy {env.ADMIN_TOOLBAR_DEV_SERVER} {
                header_up Host {http.reverse_proxy.upstream.hostport}
                header_up X-Forwarded-Host {host}
                fail_duration 1s
                unhealthy_request_count 1
            }
        }

        # Everything else under /ghost/assets/* — serve the BUILT admin from the
        # Ghost backend (TownBrief: no Vite admin dev server needed; the built
        # admin ships in the image at core/built/admin). Re-add the /ghost/assets
        # prefix that strip_prefix above removed.
        handle {
            rewrite * /ghost/assets{path}
            reverse_proxy {env.GHOST_BACKEND} {
                header_up Host {host}
                header_up X-Forwarded-Proto https
            }
        }
    }

    # Auth frame - must go to Ghost backend for comment admin authentication
    handle /ghost/auth-frame/* {
        reverse_proxy {env.GHOST_BACKEND} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # JWKS endpoint - must go to Ghost backend for JWT verification
    handle /ghost/.well-known/* {
        reverse_proxy {env.GHOST_BACKEND} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # Vite dev server lives under its own prefix so its internals
    # (HMR client, module graph, refresh runtime) don't collide with the
    # /ghost/* paths Ghost serves in production. Handles HMR WebSocket upgrade.
    handle /__admin-dev__* {
        reverse_proxy {env.ADMIN_DEV_SERVER} {
            header_up X-Forwarded-Host {host}
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
        }
    }

    # Admin HTML entry — proxy to Vite, which serves the dev index.html
    # combining Ember + React shell scripts. Matches `/ghost` and `/ghost/`
    # exactly; deep links fall through to Ghost below so its redirect
    # middleware turns them into hash URLs.
    # Requires `cd apps/admin && pnpm dev` running on the host at port 5174.
    @admin_html path /ghost /ghost/
    handle @admin_html {
        reverse_proxy {env.GHOST_BACKEND} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # Everything else under /ghost/* (deep links, redirects, etc.) goes to
    # Ghost so the same Express middleware runs in dev as in production.
    # TownBrief: the matcher must NOT include exact `/ghost` or `/ghost/`
    # — otherwise Caddy's path-specificity sort makes this block beat
    # `@admin_html` (which targets those two exact paths) since `/ghost/*`
    # is longer than `/ghost/`, leaving the React admin shell unreachable.
    @ghost_deep {
        path /ghost/*
        not path /ghost /ghost/
    }
    handle @ghost_deep {
        reverse_proxy {env.GHOST_BACKEND} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # Front-end (everything not matched above). TownBrief edge caching, gated by
    # WP_EDGE_CACHE (default off → normal dev is uncached). See deploy/EDGE-CACHING.md.

    # (1) NEVER cache: member APIs / portal data + link-tracking redirects.
    @fe_never path /members* /r/*
    handle @fe_never {
        import ghost_proxy
    }

    # (2) Cacheable: ONLY when WP_EDGE_CACHE=on, ANONYMOUS (no member cookie) GET/HEAD.
    #     {$WP_EDGE_CACHE:false} substitutes to the bare CEL literal true/false at load.
    @fe_cacheable {
        expression {$WP_EDGE_CACHE:false}
        method GET HEAD
        not header Cookie *ghost-members-ssr*
    }
    handle @fe_cacheable {
        cache
        reverse_proxy {env.GHOST_BACKEND} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto https
            # Ghost sends `Cache-Control: max-age=0` on HTML (member-aware), so Souin
            # revalidates every request. Override to a short micro-cache window on this
            # ANONYMOUS path so the cache actually serves. Applies to the whole cacheable
            # path; Souin still refuses to store responses with its own no-store rules.
            # (Prod refinement: scope to 200s via handle_response — see EDGE-CACHING.md.)
            header_down Cache-Control "public, max-age=60, stale-while-revalidate=600"
        }
    }

    # (3) Everything else (POST, logged-in members, …) — straight through, uncached.
    handle {
        import ghost_proxy
    }

    # Handle errors
    handle_errors {
        # Koenig Lexical: Ghost backend serves the built koenig-lexical
        # package out of node_modules, so fall back there when the dev
        # server is down.
        @lexical_fallback `{http.request.orig_uri.path}.startsWith("/ghost/assets/koenig-lexical/")`
        handle @lexical_fallback {
            rewrite * {http.request.orig_uri.path}
            reverse_proxy {env.GHOST_BACKEND} {
                header_up Host {host}
                header_up X-Forwarded-Proto https
            }
        }

        # Public widgets: when the host dev server is unreachable, redirect
        # to the jsDelivr CDN bundles that match Ghost's default versions
        # (see ghost/core/core/shared/config/defaults.json). This keeps
        # Portal signin/subscribe, comments, search, announcement, signup
        # form, and the admin toolbar working without anyone running each
        # `pnpm dev` on the host. Versions are pinned here — bump when the
        # corresponding defaults.json entry changes.
        @portal_fallback `{http.request.orig_uri.path}.startsWith("/ghost/assets/portal/")`
        handle @portal_fallback {
            redir https://cdn.jsdelivr.net/ghost/portal@~2.69/umd/portal.min.js 302
        }
        @comments_fallback `{http.request.orig_uri.path}.startsWith("/ghost/assets/comments-ui/")`
        handle @comments_fallback {
            redir https://cdn.jsdelivr.net/ghost/comments-ui@~1.5/umd/comments-ui.min.js 302
        }
        @signup_fallback `{http.request.orig_uri.path}.startsWith("/ghost/assets/signup-form/")`
        handle @signup_fallback {
            redir https://cdn.jsdelivr.net/ghost/signup-form@~0.3/umd/signup-form.min.js 302
        }
        @search_js_fallback `{http.request.orig_uri.path} == "/ghost/assets/sodo-search/sodo-search.min.js"`
        handle @search_js_fallback {
            redir https://cdn.jsdelivr.net/ghost/sodo-search@~1.8/umd/sodo-search.min.js 302
        }
        @search_css_fallback `{http.request.orig_uri.path} == "/ghost/assets/sodo-search/main.css"`
        handle @search_css_fallback {
            redir https://cdn.jsdelivr.net/ghost/sodo-search@~1.8/umd/main.css 302
        }
        @announcement_fallback `{http.request.orig_uri.path}.startsWith("/ghost/assets/announcement-bar/")`
        handle @announcement_fallback {
            redir https://cdn.jsdelivr.net/ghost/announcement-bar@~1.1/umd/announcement-bar.min.js 302
        }
        @toolbar_fallback `{http.request.orig_uri.path}.startsWith("/ghost/assets/admin-toolbar/")`
        handle @toolbar_fallback {
            redir https://cdn.jsdelivr.net/ghost/admin-toolbar@~0.1/umd/admin-toolbar.min.js 302
        }

        # Default error response
        respond "{err.status_code} {err.status_text}"
    }
}
